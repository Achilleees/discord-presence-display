{
  "name": "discord-presence-display",
  "displayName": "Claude Spinner for Discord",
  "description": "Displays rotating Claude Code spinner words as your Discord Rich Presence",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "Achilleees",
  "author": {
    "name": "Achilleees",
    "url": "https://github.com/Achilleees"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Achilleees/discord-presence-display.git"
  },
  "homepage": "https://github.com/Achilleees/discord-presence-display#readme",
  "bugs": {
    "url": "https://github.com/Achilleees/discord-presence-display/issues"
  },
  "keywords": [
    "discord",
    "rich-presence",
    "status",
    "spinner",
    "claude"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#5865F2",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "assets/icon.png",
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "package": "vsce package"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
